# ────┬───┬───────┬───────┬─────┬───────────────┬─────
#    │   │       │       │     │ Database (usada pelo Prisma)
#    │   │       │       │     │ Quando rodando via docker-compose, o host é "company-analyzer-db"
#    │   │       │       │     │ Quando rodando localmente, use "localhost"
#    │   │       │       └─────┬───────
#    │   │       └─────────────┼─────
#    │   └─────────────────────┼──────
#    └─────────────────────────┼───────
# ────┴───┴───────┴───────┴─────┴───────────────┴─────
DATABASE_URL=postgresql://${RAVEL_POSTGRES_USER:-panap}:${RAVEL_POSTGRES_PASSWORD:-panap_secret}@localhost:5436/panap_company_analyzer

# ────┬───┬───────┬───────┬─────┬───────────────┬─────
#    │   │       │       │     │ PostgreSQL (usadas pelo docker-compose)
#    │   │       │       │     └──────────────────────────────────────────
#    │   │       │       └─────
#    │   │       └─────────────
#    │   └─────────────────────
#    └─────────────────────────
# ────┴───┴───────┴───────┴─────┴───────────────┴─────
POSTGRES_USER=${RAVEL_POSTGRES_USER:-panap}
POSTGRES_PASSWORD=${RAVEL_POSTGRES_PASSWORD:-panap_secret}
POSTGRES_DB=panap_company_analyzer
POSTGRES_PORT=5436

# ────┬───┬───────┬───────┬─────┬───────────────┬─────
#    │   │       │       │     │ Port
#    │   │       │       └─────┬──────
#    │   │       └─────────────┼─────
#    │   └─────────────────────┼──────
#    └─────────────────────────┼───────
# ────┴───┴───────┴───────┴─────┴───────────────┴─────
PORT=3001

# ────┬───┬───────┬───────┬─────┬───────────────┬─────
#    │   │       │       │     │ Redis Configuration
#    │   │       │       └─────┬──────
#    │   │       └─────────────┼─────
#    │   └─────────────────────┼──────
#    └─────────────────────────┼───────
# ────┴───┴───────┴───────┴─────┴───────────────┴─────
REDIS_HOST=localhost
REDIS_PORT=6379

# ────┬───┬───────┬───────┬─────┬───────────────┬─────
#    │   │       │       │     │ Neo4j Configuration
#    │   │       │       └─────┬──────
#    │   │       └─────────────┼─────
#    │   └─────────────────────┼──────
#    └─────────────────────────┼───────
# ────┴───┴───────┴───────┴─────┴───────────────┴─────
NEO4J_URI=bolt://${RAVEL_NEO4J_USERNAME:-neo4j}@localhost:7687
NEO4J_USERNAME=${RAVEL_NEO4J_USERNAME:-neo4j}
NEO4J_PASSWORD=${RAVEL_NEO4J_PASSWORD:-neo4j_password}

# ────┬───┬───────┬───────┬─────┬───────────────┬─────
#    │   │       │       │     │ Pricer URL
#    │   │       │       └─────┬──────
#    │   │       └─────────────┼─────
#    │   └─────────────────────┼──────
#    └─────────────────────────┼───────
# ────┴───┴───────┴───────┴─────┴───────────────┴─────
PRICER_URL=http://localhost:3003

# ────┬───┬───────┬───────┬─────┬───────────────┬─────
#    │   │       │       │     │ S3 Configuration
#    │   │       │       └─────┬──────
#    │   │       └─────────────┼─────
#    │   └─────────────────────┼──────
#    └─────────────────────────┼───────
# ────┴───┴───────┴───────┴─────┴───────────────┴─────
S3_BUCKET=${RAVEL_S3_BUCKET:-panap-uploads}
S3_REGION=${RAVEL_S3_REGION:-us-east-1}
AWS_ACCESS_KEY_ID=${RAVEL_AWS_ACCESS_KEY_ID:-}
AWS_SECRET_ACCESS_KEY=${RAVEL_AWS_SECRET_ACCESS_KEY:-}
