// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// UploadedFile — Controle de arquivos uploads
// ─────────────────────────────────────────────────────────────────────────────

model File {
  id          String     @id() @default(uuid())
  filename    String
  type        String
  size        Int
  uploadedAt  DateTime   @default(now())
  processedAt DateTime?
  status      String     @default("pending") // pending, processed, failed
  company     Company    @relation(fields: [companyId], references: [id])
  analyses    Analysis[]
  companyId   String
}

// --- NÚCLEO DE IDENTIDADE ---

model Company {
  id        String   @id @default(uuid())
  ticker    String   @unique // Ex: PETR4
  name      String? // Nome Social (Extraído pela IA)
  sector    String? // Setor de atuação
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  analyses  Analysis[]
  situation Situation?
  files     File[]
  signals   Signal[]
}

// --- NÚCLEO DE ANÁLISE DE DOCUMENTOS (PDF) ---

model Analysis {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  period String // Ex: 1T26, 4T25
  status ReviewStatus @default(PENDING) // A trava de segurança humana

  // Dados Fixos Extraídos (Métricas Financeiras)
  revenue      Float? // Receita Líquida
  ebitda       Float? // EBITDA
  ebitdaMargin Float? // Margem EBITDA (%)
  netProfit    Float? // Lucro Líquido
  netMargin    Float? // Margem Líquida (%)
  netDebt      Float? // Dívida Líquida
  leverage     Float? // Dívida Líquida / EBITDA (Alavancagem)
  fco          Float? // Fluxo de Caixa Operacional
  capex        Float? // Investimentos
  dividends    Float? // Dividendos declarados no período

  // Inteligência da IA
  aiSensation Float? // Impacto pontual (0 a 10)
  aiSummary   String? @db.Text // Resumo da tese da IA para o período
  projection  Json? // Projeções para o próximo trimestre { profit: X, capex: Y }

  // Controle de Auditoria
  file       File      @relation(fields: [fileId], references: [id]) // Caminho/URL do PDF processado
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  fileId     String

  // Relacionamento com Signals
  signals AnalysisSignal[]

  @@index([companyId])
  @@index([period])
}

// --- NÚCLEO DE STATUS DE LONGO PRAZO ---

model Situation {
  id        String  @id @default(uuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  healthStatus HealthStatus @default(SAUDAVEL)
  trend        Trend        @default(ESTAVEL)

  // Visão Sintetizada
  lastAnalysisId   String? // ID da última análise aprovada que definiu este status
  futureProjection Json? // Dados consolidados do que esperar { expectedRevenue: 1000, timeframe: "2Q26" }

  updatedAt DateTime @updatedAt
}

// --- ENUMS (REGRAS DE NEGÓCIO) ---

enum ReviewStatus {
  PENDING // Aguardando sua revisão humana
  APPROVED // Validado, agora conta para o histórico e Situation
  REJECTED // Dado descartado (erro de leitura da IA)
}

enum HealthStatus {
  MUITO_SAUDAVEL
  SAUDAVEL
  INSTAVEL
  DOENTE
  MUITO_DOENTE
}

enum Trend {
  MELHORANDO
  ESTAVEL
  PIORANDO
}

// ─────────────────────────────────────────────────────────────────────────────
// Signal — Sinais de mercado recebidos do news-analyzer
// ─────────────────────────────────────────────────────────────────────────────

enum SignalSource {
  SENTIMENT
  FUNDAMENTAL
  PRICE
}

model Signal {
  id        String       @id @default(uuid())
  ticker    String
  source    SignalSource
  score     Float // -1 a 1
  reasoning String?      @db.Text
  processed Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Relacionamento com Analysis
  analyses  AnalysisSignal[]
  company   Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String?

  @@index([ticker])
  @@index([source])
  @@index([processed])
}

model AnalysisSignal {
  analysisId String
  signalId   String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  signal     Signal   @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@id([analysisId, signalId])
}
