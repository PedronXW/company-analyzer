// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// UploadedFile — Controle de arquivos uploads
// ─────────────────────────────────────────────────────────────────────────────

model File {
  id               String        @id() @default(uuid())
  filename         String
  type             String
  size             Int
  uploadedAt       DateTime      @default(now())
  processedAt      DateTime?
  status           String        @default("pending") // pending, processed, analyzed, failed
  period           String?       // Período do documento (ex: "1T26") - extraído do PDF
  periodConfidence Int?          // Confiança da extração do período (0-100)
  sections         Section[]
  company          Company       @relation(fields: [companyId], references: [id])
  analyses         Analysis[]
  fluxoAnalysis    FluxoAnalysis[]
  companyId        String
}

// --- NÚCLEO DE SEÇÕES DE DOCUMENTO ---

model Section {
  id            String       @id @default(uuid())
  fileId        String
  file          File         @relation(fields: [fileId], references: [id], onDelete: Cascade)
  title         String
  description   String?      @db.Text
  pageStart     Int
  pageEnd       Int
  orderIndex    Int
  type          String       @default("NORMAL") // NORMAL (para processar), IGNORE (para pular)
  data          Json         @default("{}") // Dados extraídos da seção
  status        String       @default("pending") // pending, analyzed, failed
  error         String?      @db.Text
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([fileId])
  @@index([orderIndex])
  @@index([type])
}

// --- NÚCLEO DE IDENTIDADE ---

model Company {
  id        String   @id @default(uuid())
  ticker    String   @unique // Ex: PETR4
  name      String? // Nome Social (Extraído pela IA)
  sector    String? // Setor de atuação
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  analyses  Analysis[]
  situation Situation?
  files     File[]
  signals   Signal[]
}

// --- NÚCLEO DE ANÁLISE DE DOCUMENTOS (PDF) ---

model Analysis {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  period String // Ex: 1T26, 4T25
  status ReviewStatus @default(PENDING) // A trava de segurança humana

  // Dados Fixos Extraídos (Métricas Financeiras)
  revenue      Float? // Receita Líquida
  ebitda       Float? // EBITDA
  ebitdaMargin Float? // Margem EBITDA (%)
  netProfit    Float? // Lucro Líquido
  netMargin    Float? // Margem Líquida (%)
  netDebt      Float? // Dívida Líquida
  leverage     Float? // Dívida Líquida / EBITDA (Alavancagem)
  fco          Float? // Fluxo de Caixa Operacional
  capex        Float? // Investimentos
  dividends    Float? // Dividendos declarados no período

  // Inteligência da IA
  aiSensation Float? // Impacto pontual (0 a 10)
  aiSummary   String? @db.Text // Resumo da tese da IA para o período
  projection  Json? // Projeções para o próximo trimestre { profit: X, capex: Y }

  // Controle de Auditoria
  file       File      @relation(fields: [fileId], references: [id]) // Caminho/URL do PDF processado
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  fileId     String

  // Relacionamento com Signals
  signals AnalysisSignal[]

  @@index([companyId])
  @@index([period])
}

// --- NÚCLEO DE EXTRAÇÃO BRUTA (TEMPORÁRIO PARA ANALISE) ---

// --- NÚCLEO DE STATUS DE LONGO PRAZO ---

model Situation {
  id        String  @id @default(uuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  healthStatus HealthStatus @default(SAUDAVEL)
  trend        Trend        @default(ESTAVEL)

  // Visão Sintetizada
  lastAnalysisId   String? // ID da última análise aprovada que definiu este status
  futureProjection Json? // Dados consolidados do que esperar { expectedRevenue: 1000, timeframe: "2Q26" }

  updatedAt DateTime @updatedAt
}

// --- ENUMS (REGRAS DE NEGÓCIO) ---

enum ReviewStatus {
  PENDING // Aguardando sua revisão humana
  APPROVED // Validado, agora conta para o histórico e Situation
  REJECTED // Dado descartado (erro de leitura da IA)
}

enum HealthStatus {
  MUITO_SAUDAVEL
  SAUDAVEL
  INSTAVEL
  DOENTE
  MUITO_DOENTE
}

enum Trend {
  MELHORANDO
  ESTAVEL
  PIORANDO
}

// ─────────────────────────────────────────────────────────────────────────────
// Signal — Sinais de mercado recebidos do news-analyzer
// ─────────────────────────────────────────────────────────────────────────────

enum SignalSource {
  SENTIMENT
  FUNDAMENTAL
  PRICE
}

model Signal {
  id        String       @id @default(uuid())
  ticker    String
  source    SignalSource
  score     Float // -1 a 1
  reasoning String?      @db.Text
  processed Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Relacionamento com Analysis
  analyses  AnalysisSignal[]
  company   Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String?

  @@index([ticker])
  @@index([source])
  @@index([processed])
}

model AnalysisSignal {
  analysisId String
  signalId   String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  signal     Signal   @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@id([analysisId, signalId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FluxoAnalysis — Análise de Comparação entre Lançamentos de Resultados
// ─────────────────────────────────────────────────────────────────────────────

/**
 * Armazena análise de fluxo entre lançamentos de resultados.
 * Cada FluxoAnalysis compara um lançamento atual com o anterior (ou referência).
 *
 * OBS: Armazenamos apenas os IDs dos arquivos (currentFileId, previousFileId)
 * para evitar ambiguidade de relações. Para acessar os arquivos completos,
 * use queries explícitas no service.
 */
model FluxoAnalysis {
  id               String        @id @default(uuid())
  currentFileId    String        // ID do File que está sendo comparado (atual)
  currentFile      File          @relation(fields: [currentFileId], references: [id])

  previousFileId   String?       // ID do File anterior (comparado)
  // NOTA: previousFile não é mapeado como relação para evitar ambiguidade
  // Acesse via query: prisma.file.findUnique({ where: { id: fluxoAnalysis.previousFileId } })

  periodComparison String        // Ex: "1T26 vs 4T25"
  comparisonType   ComparisonType @default(sequential) // YOY, QOQ, sequential

  // Variações absolutas e percentuais para cada métrica
  revenueChange     Float?       // Variação absoluta
  revenueChangePct  Float?       // Variação percentual
  revenueTrend      FluxoTrend?

  ebitdaChange      Float?
  ebitdaChangePct   Float?
  ebitdaTrend       FluxoTrend?

  netProfitChange   Float?
  netProfitChangePct Float?
  netProfitTrend    FluxoTrend?

  fcoChange         Float?
  fcoChangePct      Float?
  fcoTrend          FluxoTrend?

  dividendsChange   Float?
  dividendsChangePct Float?
  dividendsTrend    FluxoTrend?

  // Indicadores de qualidade do fluxo
  qualityScore      Float?       // 0-10, avalia consistência e qualidade dos dados
  anomalyDetected   Boolean      @default(false) // Alerta de anomalia
  anomalyReason     String?      @db.Text

  // Resumo da análise de fluxo
  fluxoSummary      String?      @db.Text // Resumo da evolução da empresa
  fluxoSensation    Float?       // Sentimento do fluxo (0-10)

  analyzedAt        DateTime     @default(now())
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([currentFileId])
  @@index([previousFileId])
}

// --- ENUMS COMPLEMENTARES ---

enum ComparisonType {
  YOY       // Year-over-Year (mesmo período do ano anterior)
  QOQ       // Quarter-over-Quarter (trimestre anterior)
  sequential // Seqüencial (último lançamento disponível)
}

enum FluxoTrend {
  ACCELERATING    // Crescimento acelerando (positivo e variação aumentando)
  IMPROVING       // Melhorando (positivo mas desacelerando)
  STABLE          // Estável (variação próxima de 0 ou constante)
  DECLINING       // Decrescendo (negativo mas estabilizando)
  DETERIORATING   // Piorando (negativo e piorando)
}
